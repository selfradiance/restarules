    "required": true,
    "amount": 50,
    "currency": "USD",
    "refundable": false
  },
  "cancellation_policy": {
    "penalty_applies": true,
    "window_minutes": 1440,
    "penalty_amount": 25,
    "currency": "USD"
  },
  "no_show_policy": {
    "fee": 50,
    "currency": "USD",
    "grace_period_minutes": 15
