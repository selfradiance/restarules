    "phrasing": "I am an AI assistant."
  },
  "allowed_channels": ["phone", "web"],
  "rate_limits": [
    {
      "action": "booking_request",
      "limit": 3,
      "window_value": 1,
      "window_unit": "hour"
    },
    {
      "action": "booking_request",
      "limit": 1,
      "window_value": 1,
      "window_unit": "minute",
      "applies_to": ["create_booking"]
    }
  ],
  "human_escalation_required": {
