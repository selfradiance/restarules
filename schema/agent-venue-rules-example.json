{
  "schema_version": "0.2",
  "venue_name": "The Golden Fork",
  "venue_url": "https://www.thegoldenfork.com",
  "last_updated": "2026-03-09",
  "effective_at": "2026-03-09",

  "default_policy": "deny_if_unspecified",

  "venue_currency": "USD",
  "venue_timezone": "America/New_York",

  "disclosure_required": {
    "enabled": true,
    "phrasing": "You must identify yourself as an AI agent before making any request."
  },

  "allowed_channels": ["phone", "web"],

  "rate_limits": [
    {
      "action": "booking_request",
      "limit": 3,
      "window_unit": "hour",
      "window_value": 1,
      "applies_to": ["create_booking", "modify_booking"]
    }
  ],

  "human_escalation_required": {
    "conditions": [
      "special_event_booking",
      "complaint_or_dispute"
    ]
  },

  "party_size_policy": {
    "auto_book_max": 6
  },

  "third_party_restrictions": {
    "no_resale": true,
    "no_transfer": true,
    "identity_bound_booking": true
  },

  "deposit_policy": {
    "required": true,
    "amount": 50,
    "currency": "USD",
    "refundable": true
  },

  "cancellation_policy": {
    "penalty_applies": true,
    "window_minutes": 1440,
    "penalty_amount": 50,
    "currency": "USD"
  },

  "no_show_policy": {
    "fee": 100,
    "currency": "USD",
    "grace_period_minutes": 15
  },

  "user_acknowledgment_requirements": ["deposit_policy", "cancellation_policy", "no_show_policy"],

  "complaint_endpoint": "https://www.thegoldenfork.com/report-agent"
}
